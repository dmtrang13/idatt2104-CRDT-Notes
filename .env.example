# Copy to .env for local Docker Compose configuration.
HOST=0.0.0.0
HTTP_PORT=3000
WS_PORT=3001
DATABASE_URL=postgres://crdt:crdt@postgres:5432/crdt_notes

# Leave AUTH_TOKEN empty only for an open local demo.
# Set REQUIRE_AUTH=true, or NODE_ENV=production, to fail startup without a token.
REQUIRE_AUTH=false
# URL tokens are disabled by default because they leak through browser history/logs.
ALLOW_URL_TOKENS=false
AUTH_TOKEN=9f7b2d1c4e6a8b3f5d0c1a7e9b2d4f6

# Optional per-document tokens. Supports JSON:
# DOCUMENT_TOKENS={"notes-1":"secret-a","notes-2":"secret-b"}
# Or comma-separated entries:
# DOCUMENT_TOKENS=notes-1=secret-a,notes-2=secret-b
DOCUMENT_TOKENS={"notes-main":"a8c41f7d2e9b5c63","research-doc":"f29c7e1a4d8b6c52","demo-room":"7d4f2b9c1e6a3f85","team-alpha":"c5e18a7d3f2b9c64"}

# Comma-separated WebSocket Origin allowlist. Add deployed domains here.
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Basic payload limits.
MAX_MESSAGE_BYTES=262144
MAX_OP_VALUE_CHARS=1
