{
  "version": 3,

  "configurePresets": [
    {
      "name": "msys-ucrt",
      "displayName": "Windows MSYS2 UCRT64 Ninja",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build-ucrt",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_CXX_COMPILER": "C:/msys64/ucrt64/bin/c++.exe"
      },
      "environment": {
        "PATH": "C:/msys64/ucrt64/bin;$penv{PATH}"
      }
    },

    {
      "name": "windows-msvc",
      "displayName": "Windows MSVC Debug",
      "generator": "Visual Studio 17 2022",
      "binaryDir": "${sourceDir}/build-msvc",
      "cacheVariables": {
        "CMAKE_CONFIGURATION_TYPES": "Debug;Release"
      }
    },

    {
      "name": "linux-debug",
      "displayName": "Linux Ninja Debug",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build-linux",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },

    {
      "name": "macos-debug",
      "displayName": "macOS Ninja Debug",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build-macos",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    }
  ],

  "buildPresets": [
    {
      "name": "msys-ucrt",
      "configurePreset": "msys-ucrt"
    },
    {
      "name": "windows-msvc",
      "configurePreset": "windows-msvc",
      "configuration": "Debug"
    },
    {
      "name": "linux-debug",
      "configurePreset": "linux-debug"
    },
    {
      "name": "macos-debug",
      "configurePreset": "macos-debug"
    }
  ],

  "testPresets": [
    {
      "name": "msys-ucrt",
      "configurePreset": "msys-ucrt"
    },
    {
      "name": "windows-msvc",
      "configurePreset": "windows-msvc",
      "configuration": "Debug"
    },
    {
      "name": "linux-debug",
      "configurePreset": "linux-debug"
    },
    {
      "name": "macos-debug",
      "configurePreset": "macos-debug"
    }
  ]
}